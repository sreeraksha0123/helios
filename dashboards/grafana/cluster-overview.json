{
  "title": "Helios / Cluster Overview",
  "uid": "helios-cluster-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "tags": ["helios", "cluster"],
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Node Ready Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(kube_node_status_condition{condition='Ready', status='true'})", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Cluster CPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(node_cpu_seconds_total{mode!='idle'}[5m])) / sum(machine_cpu_cores)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Cluster Memory Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 18, "y": 0 },
      "targets": [
        { "expr": "1 - (sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Pods by Phase",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (phase) (kube_pod_status_phase)", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Pod Restarts (rate, 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        { "expr": "topk(10, sum by (namespace, pod) (rate(kube_pod_container_status_restarts_total[5m])))", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Disk Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "1 - (node_filesystem_avail_bytes{fstype!='tmpfs'} / node_filesystem_size_bytes{fstype!='tmpfs'})", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Network I/O by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum by (instance) (rate(node_network_receive_bytes_total[5m]))", "refId": "A", "legendFormat": "{{instance}} rx" },
        { "expr": "sum by (instance) (rate(node_network_transmit_bytes_total[5m]))", "refId": "B", "legendFormat": "{{instance}} tx" }
      ]
    }
  ]
}
