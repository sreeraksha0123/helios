{
  "title": "Helios / MTTR Tracking",
  "uid": "helios-mttr-tracking",
  "timezone": "browser",
  "schemaVersion": 39,
  "tags": ["helios", "mttr"],
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MTTR Trend (1h rolling)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "targets": [
        { "expr": "helios:mttr_seconds_1h", "refId": "A", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "id": 2,
      "title": "Current MTTR Improvement vs 7d Baseline",
      "type": "gauge",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": -1, "max": 1 } },
      "targets": [
        { "expr": "helios:mttr_improvement_ratio", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Incidents per Day",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "targets": [
        { "expr": "sum by (namespace) (increase(helios:incident_resolution_seconds[1d]))", "refId": "A" }
      ]
    }
  ]
}
